{
  "name": "@port/openfga-client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup",
    "lint": "eslint .",
    "codegen": "dotenv -- openfga-types-gen --config ./openfga-types.config.json"
