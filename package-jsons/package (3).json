{
  "name": "@port/open-webui",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "codegen": "openapi-typescript <redacted>/openapi.json --empty-objects-unknown -o ./schema.d.ts",
    "lint": "eslint .",
    "build": "tsup"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./types": {
      "types": "./schema.d.ts"
    }
  },
  "devDependencies": {
    "@port/common-schemas": "*",
    "@port/eslint-config": "*",
    "@port/ts-config": "*",
    "@port/tsup-config": "*",
    "@types/node": "^20.3.1",
    "openapi-typescript": "^7.6.1",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "ai": "^5.0.116",
    "openapi-fetch": "^0.13.5",
    "zod": "4.0.5",
    "@ai-sdk/openai": "^2.0.88"
  }
}