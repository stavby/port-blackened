    "lodash": "^4.17.21",
    "@port/common-schemas": "*"
  },
  "devDependencies": {
    "@port/eslint-config": "*",
    "@port/ts-config": "*",
    "@port/tsup-config": "*",
    "@types/lodash": "^4.17.16",
    "dotenv-cli": "^7.3.0",
    "@port/openfga-types-gen": "^1.0.0",
    "tsup": "^8.3.6"
  },
